          "name": "UsedAmount",
          "output_required": false,
          "type": "int",
          "value_allowed_null": false
        },
        {
          "document": "唯一请求 ID，由服务端生成，每次请求都会返回（若请求因其他原因未能抵达服务端，则该次请求不会获得 RequestId）。定位问题时需要提供该次请求的 RequestId。",
          "member": "string",
          "name": "RequestId",
          "type": "string"
        }
      ],
      "type": "object"
    },
    "TransDetail": {
      "document": "大模型图片翻译详情信息",
      "members": [
        {
          "disabled": false,
          "document": "<p>当前行的原文本</p>",
          "example": "你好",
          "member": "string",
          "name": "SourceLineText",
          "output_required": false,
          "type": "string",
          "value_allowed_null": false
        },
        {
