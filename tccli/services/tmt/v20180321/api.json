{
  "actions": {
    "ImageTranslateLLM": {
      "document": "提供18种语言的图片翻译服务，可自动识别图片中的文本内容并翻译成目标语言，识别后的文本按行翻译，后续会提供可按段落翻译的版本。\n\n- 输入图片格式：png、jpg、jpeg等常用图片格式，不支持gif动图。\n- 输出图片格式：jpg。\n\n提示：对于一般开发者，我们建议优先使用SDK接入简化开发。SDK使用介绍请直接查看 5. 开发者资源 部分。",
      "input": "ImageTranslateLLMRequest",
      "name": "端到端图片翻译",
      "output": "ImageTranslateLLMResponse",
      "status": "online"
    }
  },
  "metadata": {
    "apiVersion": "2018-03-21",
    "api_brief": "介绍如何使用API对机器翻译进行操作，包括文本翻译、文档翻译、图片翻译和语音翻译等。",
    "serviceNameCN": "机器翻译",
    "serviceShortName": "tmt"
  },
  "objects": {
    "BoundingBox": {
      "document": "段落文本框位置：x，y代表左上顶点，width和height代表宽高",
      "members": [
        {
          "disabled": false,
          "document": "<p>左上顶点x坐标</p>",
          "example": "0",
          "member": "int64",
          "name": "X",
          "output_required": false,
          "type": "int",
          "value_allowed_null": false
        },
        {
          "disabled": false,
          "document": "<p>左上顶点y坐标</p>",
          "example": "0",
          "member": "int64",
          "name": "Y",
          "output_required": false,
          "type": "int",
          "value_allowed_null": false
        },
        {
          "disabled": false,
          "document": "<p>宽</p><p>单位：px</p>",
          "example": "10",
          "member": "int64",
          "name": "Width",
          "output_required": false,
          "type": "int",
          "value_allowed_null": false
        },
        {
          "disabled": false,
          "document": "<p>高</p><p>单位：px</p>",
          "example": "10",
          "member": "int64",
          "name": "Height",
          "output_required": false,
          "type": "int",
          "value_allowed_null": false
        }
      ],
      "usage": "out"
    },
    "Coord": {
      "document": "坐标详细信息",
      "members": [
        {
          "disabled": false,
          "document": "X坐标",
          "example": "10",
          "member": "int64",
          "name": "X",
          "output_required": false,
          "required": false,
          "type": "int",
          "value_allowed_null": false
